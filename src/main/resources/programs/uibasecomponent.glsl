3e4\u003c/span\u003e;","\u003cspan class=\"pl-k\"\u003econst\u003c/span\u003e \u003cspan class=\"pl-k\"\u003eint\u003c/span\u003e UI_TEXT_FIELD_COMPONENT \u003cspan class=\"pl-k\"\u003e=\u003c/span\u003e \u003cspan class=\"pl-c1\"\u003e5\u003c/span\u003e;","\u003cspan class=\"pl-k\"\u003econst\u003c/span\u003e \u003cspan class=\"pl-k\"\u003eint\u003c/span\u003e UI_COLOR_PICKER_COMPONENT \u003cspan class=\"pl-k\"\u003e=\u003c/span\u003e \u003cspan class=\"pl-c1\"\u003e6\u003c/span\u003e;","\u003cspan class=\"pl-k\"\u003econst\u003c/span\u003e \u003cspan class=\"pl-k\"\u003eint\u003c/span\u003e UI_IMAGE_COMPONENT \u003cspan class=\"pl-k\"\u003e=\u003c/span\u003e \u003cspan class=\"pl-c1\"\u003e7\u003c/span\u003e;","\u003cspan class=\"pl-k\"\u003econst\u003c/span\u003e \u003cspan class=\"pl-k\"\u003eint\u003c/span\u003e UI_LAYOUT_VERTICAL_COMPONENT \u003cspan class=\"pl-k\"\u003e=\u003c/span\u003e \u003cspan class=\"pl-c1\"\u003e8\u003c/span\u003e;","\u003cspan class=\"pl-k\"\u003econst\u003c/span\u003e \u003cspan class=\"pl-k\"\u003eint\u003c/span\u003e UI_LAYOUT_HORIZONTAL_COMPONENT \u003cspan class=\"pl-k\"\u003e=\u003c/span\u003e \u003cspan class=\"pl-c1\"\u003e9\u003c/span\u003e;","\u003cspan class=\"pl-k\"\u003econst\u003c/span\u003e \u003cspan class=\"pl-k\"\u003eint\u003c/span\u003e UI_SPACER_COMPONENT \u003cspan class=\"pl-k\"\u003e=\u003c/span\u003e \u003cspan class=\"pl-c1\"\u003e10\u003c/span\u003e;","","\u003cspan class=\"pl-k\"\u003eout\u003c/span\u003e \u003cspan class=\"pl-k\"\u003evec4\u003c/span\u003e vPosition;","\u003cspan class=\"pl-k\"\u003eout\u003c/span\u003e \u003cspan class=\"pl-k\"\u003evec4\u003c/span\u003e vColor;","\u003cspan class=\"pl-k\"\u003eout\u003c/span\u003e \u003cspan class=\"pl-k\"\u003evec2\u003c/span\u003e vUV;","\u003cspan class=\"pl-k\"\u003eflat\u003c/span\u003e \u003cspan class=\"pl-k\"\u003eout\u003c/span\u003e \u003cspan class=\"pl-k\"\u003efloat\u003c/span\u003e vTextureIndex;","\u003cspan class=\"pl-k\"\u003eflat\u003c/